{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": [
      "node"
    ],
    "declaration": false,
    "noEmit": true,
    "useDefineForClassFields": false,
    "jsx": "preserve"
  },
  "include": [
    "backend/**/*.ts",
    "cmd/**/*.port.ts",
    "frontend/**/*.port.ts",
    "scripts/**/*.ts",
    "runtime/**/*.ts",
    "desktop/src/**/*",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "bin",
    "desktop/dist",
    "desktop/node_modules"
  ]
}
